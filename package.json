    "@types/quill": "2.0.14",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.8.0",
    "firebase-tools": "13.35.1",
    "husky": "9.1.7",
    "inquirer-autocomplete-prompt": "3.0.1",
    "lint-staged": "17.0.8",
    "modernizr": "3.13.1",
    "prettier": "3.9.5",
    "prettier-plugin-organize-imports": "4.3.0",
