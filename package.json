  "devDependencies": {
    "@angular-devkit/architect": "0.2003.32",
    "@angular-devkit/build-angular": "20.3.32",
    "@angular-eslint/builder": "20.7.0",
    "@angular-eslint/eslint-plugin": "20.7.0",
