    "eslint": "^9.39.5",
    "firebase-tools": "^14.27.0",
    "husky": "9.1.7",
    "inquirer-autocomplete-prompt": "3.0.1",
    "lint-staged": "^17.1.0",
    "modernizr": "3.13.1",
    "prettier": "^3.9.6",
